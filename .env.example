# Copy to .env and fill in. Never commit .env.
# Project: Dahotre Group Websites (ref qfeuxyuyxjkmqjpiknes, ap-south-1).

# Supabase API URL
SUPABASE_URL=https://qfeuxyuyxjkmqjpiknes.supabase.co

# Publishable anon key — Settings > API > anon (legacy) or publishable key. Injected at build into HTML.
SUPABASE_ANON_KEY=

# Service role — recommended for `npm run upload:images` only; never expose in client or commit
SUPABASE_SERVICE_ROLE_KEY=

# If empty, upload uses SUPABASE_ANON_KEY when Storage allows anon writes (see sql/storage-anon-upload-dnd-site-images.sql). Prefer service role.

# Public storage bucket for static site images (created via MCP / sql/storage-dnd-site-images.sql)
STORAGE_PUBLIC_BUCKET=dnd-site-images

# Optional: full public URL to bucket root (trailing slash). If unset, build derives from SUPABASE_URL + STORAGE_PUBLIC_BUCKET
# PUBLIC_SITE_IMAGES_BASE=https://qfeuxyuyxjkmqjpiknes.supabase.co/storage/v1/object/public/dnd-site-images/

# Vercel: set the same variables (without SERVICE_ROLE) for Production/Preview builds.
